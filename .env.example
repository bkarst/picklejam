# .env.example — every environment variable the app reads, grouped by service.
# Copy to `.env.local` and fill in real values. NEVER commit real secrets.
# `NEXT_PUBLIC_*` vars are exposed to the browser; everything else is server-only.
# Access these through lib/env.ts (do not read process.env directly).

# ── App / deployment ──────────────────────────────────────────────────────────
APP_ENV=Development                                  # Development | Test | Production (drives DynamoDB table name)
NEXT_PUBLIC_SITE_URL=https://pickleloko.com          # canonical site origin (no trailing slash)

# ── AWS / DynamoDB / S3 (server) ──────────────────────────────────────────────
AWS_REGION=us-east-1                                 # AWS region for DynamoDB + S3
DYNAMODB_ENDPOINT=                                   # set to e.g. http://localhost:8000 to use DynamoDB Local
S3_BUCKET=                                           # S3 bucket for user uploads (review photos). Needs CORS allowing PUT from the app origin + public read (or a CDN).
S3_PUBLIC_BASE_URL=                                   # optional: serve uploads via a CDN/custom domain (default: https://<bucket>.s3.<region>.amazonaws.com)
S3_PUBLIC_HOST=                                       # optional: the CDN/custom hostname to whitelist for next/image (only if S3_PUBLIC_BASE_URL uses a non-S3 host)

# ── Firebase client SDK (browser, public) ─────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=                        # Firebase Web API key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=                    # e.g. pickleloko.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=                     # Firebase project id
NEXT_PUBLIC_FIREBASE_APP_ID=                         # Firebase web app id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=                 # e.g. pickleloko.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=            # FCM sender id

# ── Firebase Admin SDK (server, secret) ───────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=                           # service-account project id
FIREBASE_ADMIN_CLIENT_EMAIL=                         # service-account client email
FIREBASE_ADMIN_PRIVATE_KEY=                          # service-account private key ("\n" escapes are converted to newlines)

# ── Stripe (server secret + public key) ───────────────────────────────────────
STRIPE_SECRET_KEY=                                   # sk_live_... / sk_test_... (server-only)
STRIPE_WEBHOOK_SECRET=                               # whsec_... signing secret (optional until webhooks are wired)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=                  # pk_live_... / pk_test_... (browser)

# ── Resend (server secret) ────────────────────────────────────────────────────
RESEND_API_KEY=                                      # re_... transactional email API key

# ── PostHog analytics (client + server) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=                             # PostHog project API key (browser)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com    # PostHog ingest host
POSTHOG_KEY=                                         # server capture key (optional; falls back to NEXT_PUBLIC_POSTHOG_KEY)
POSTHOG_HOST=                                         # server ingest host (optional; falls back to NEXT_PUBLIC_POSTHOG_HOST)

# ── Other public integrations ─────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=                    # Google AdSense publisher id
NEXT_PUBLIC_MAPBOX_TOKEN=                            # Mapbox public access token
